<%- include('partials/head') %>

<%- include('partials/navbar') %>

<div class="App" id="app">
  <main class="main-content">
    <div class="visualizer-page">
      <div class="container">

        <!-- Header -->
        <div class="visualizer-header fade-in">
          <h1 class="visualizer-title">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
              <rect x="3" y="3" width="7" height="7" stroke="currentColor" stroke-width="2" fill="none"/>
              <rect x="14" y="3" width="7" height="7" stroke="currentColor" stroke-width="2" fill="none"/>
              <rect x="14" y="14" width="7" height="7" stroke="currentColor" stroke-width="2" fill="none"/>
              <rect x="3" y="14" width="7" height="7" stroke="currentColor" stroke-width="2" fill="none"/>
            </svg>
            Dijkstra's Algorithm Visualizer
          </h1>
          <p class="visualizer-subtitle">
            Watch the shortest path algorithm in action with interactive grid visualization
          </p>
        </div>

        <!-- Instructions -->
        <div class="instructions-section slide-in-left">
          <div class="instructions-card">
            <h3>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none"/>
                <path d="M12 16v-4M12 8h.01" stroke="currentColor" stroke-width="2"/>
              </svg>
              How to Use
            </h3>
            <div class="instructions-grid">
              <div class="instruction-item">
                <div class="instruction-icon start-node-demo"></div>
                <span>Start Node (Green)</span>
              </div>
              <div class="instruction-item">
                <div class="instruction-icon finish-node-demo"></div>
                <span>Finish Node (Red)</span>
              </div>
              <div class="instruction-item">
                <div class="instruction-icon wall-node-demo"></div>
                <span>Wall (Click &amp; Drag)</span>
              </div>
              <div class="instruction-item">
                <div class="instruction-icon visited-node-demo"></div>
                <span>Visited Nodes</span>
              </div>
              <div class="instruction-item">
                <div class="instruction-icon path-node-demo"></div>
                <span>Shortest Path</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Pathfinding Visualizer -->
        <div class="visualizer-container slide-in-right">
          <div class="visualizer-card">
            <div class="pathfinding-visualizer">

              <!-- Control Panel -->
              <div class="control-panel">
                <div class="control-section">
                  <h3>Mode</h3>
                  <div class="mode-buttons">
                    <button class="mode-btn active" id="wallModeBtn" onclick="setMode('wall', this)">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2" stroke="currentColor" stroke-width="2" fill="currentColor"/>
                      </svg>
                      Add Walls
                    </button>
                    <button class="mode-btn" id="startModeBtn" onclick="setMode('start', this)">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="var(--success-color)"/>
                      </svg>
                      Move Start
                    </button>
                    <button class="mode-btn" id="finishModeBtn" onclick="setMode('finish', this)">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="var(--error-color)"/>
                      </svg>
                      Move Finish
                    </button>
                  </div>
                </div>

                <div class="control-section">
                  <h3>Speed</h3>
                  <div class="speed-buttons">
                    <button class="speed-btn" onclick="setSpeed('slow', this)">Slow</button>
                    <button class="speed-btn active" onclick="setSpeed('normal', this)">Normal</button>
                    <button class="speed-btn" onclick="setSpeed('fast', this)">Fast</button>
                  </div>
                </div>

                <div class="control-section">
                  <h3>Actions</h3>
                  <div class="action-buttons">
                    <button class="action-btn visualize-btn" id="visualizeBtn" onclick="visualizeDijkstra()">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                        <polygon points="5,3 19,12 5,21" fill="currentColor"/>
                      </svg>
                      Visualize
                    </button>
                    <button class="action-btn reset-btn" id="resetBtn" onclick="clearGrid()">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                        <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8" stroke="currentColor" stroke-width="2" fill="none"/>
                        <path d="M21 3v5h-5M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16" stroke="currentColor" stroke-width="2" fill="none"/>
                        <path d="M8 16l-5 5v-5h5" stroke="currentColor" stroke-width="2" fill="none"/>
                      </svg>
                      Reset Grid
                    </button>
                  </div>
                </div>
              </div>

              <!-- Mode Indicator -->
              <div class="mode-indicator">
                <span class="mode-text">
                  Current Mode: <strong id="modeIndicatorText">Adding Walls (Click and drag to create walls)</strong>
                </span>
              </div>

              <!-- Grid -->
              <div class="grid-container">
                <div class="grid" id="grid"></div>
              </div>

            </div>
          </div>
        </div>

        <!-- Algorithm Details -->
        <div class="algorithm-details fade-in">
          <h2>Algorithm Details</h2>
          <div class="details-grid">
            <div class="detail-card">
              <div class="detail-icon">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none"/>
                  <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2"/>
                </svg>
              </div>
              <h3>Time Complexity</h3>
              <p class="complexity-value">O((V + E) log V)</p>
              <p class="complexity-description">Where V is the number of vertices and E is the number of edges in the graph.</p>
            </div>
            <div class="detail-card">
              <div class="detail-icon">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none">
                  <path d="M12 2L2 7v10c0 5.55 3.84 9.95 9 11 5.16-1.05 9-5.45 9-11V7l-10-5z" stroke="currentColor" stroke-width="2" fill="none"/>
                </svg>
              </div>
              <h3>Space Complexity</h3>
              <p class="complexity-value">O(V)</p>
              <p class="complexity-description">Linear space complexity for storing distances and priority queue.</p>
            </div>
            <div class="detail-card">
              <div class="detail-icon">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none">
                  <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" stroke="currentColor" stroke-width="2" fill="none"/>
                </svg>
              </div>
              <h3>Algorithm Type</h3>
              <p class="complexity-value">Greedy</p>
              <p class="complexity-description">Uses a greedy approach with a priority queue to always select the closest unvisited vertex.</p>
            </div>
          </div>
        </div>

        <!-- Features -->
        <div class="features-section">
          <h2>Visualization Features</h2>
          <div class="features-grid">
            <div class="feature-item">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M12 2L2 7v10c0 5.55 3.84 9.95 9 11 5.16-1.05 9-5.45 9-11V7l-10-5z" stroke="currentColor" stroke-width="2" fill="none"/>
              </svg>
              <span>Interactive grid with drag-and-drop wall creation</span>
            </div>
            <div class="feature-item">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none"/>
                <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2"/>
              </svg>
              <span>Real-time visualization of algorithm execution</span>
            </div>
            <div class="feature-item">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" stroke="currentColor" stroke-width="2" fill="none"/>
              </svg>
              <span>Step-by-step animation showing visited nodes</span>
            </div>
            <div class="feature-item">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" stroke="currentColor" stroke-width="2" fill="none"/>
              </svg>
              <span>Highlighted shortest path from start to finish</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>
</div>

<%- include('partials/footer') %>
